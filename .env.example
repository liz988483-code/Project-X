# =====================================================
# APPLICATION
# =====================================================
NODE_ENV=development
APP_NAME=Soko E-commerce
APP_VERSION=1.0.0
APP_PORT=3000
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# =====================================================
# DATABASES
# =====================================================
# PostgreSQL - User Service
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123
POSTGRES_DB=soko_users
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
USER_DB_URL=postgresql://postgres:postgres123@localhost:5432/soko_users
DATABASE_URL=postgresql://user:password@ep-example.region.aws.neon.tech/soko?sslmode=require

# MongoDB - Products, Orders, Payments, Chat, Notifications
MONGO_USER=mongo
MONGO_PASSWORD=mongo123
MONGO_DB=soko
MONGO_HOST=localhost
MONGO_PORT=27017
PRODUCT_DB_URL=mongodb://mongo:mongo123@localhost:27017/soko_products
ORDER_DB_URL=mongodb://mongo:mongo123@localhost:27017/soko_orders
PAYMENT_DB_URL=mongodb://mongo:mongo123@localhost:27017/soko_payments
CHAT_DB_URL=mongodb://mongo:mongo123@localhost:27017/soko_chat
NOTIFICATION_DB_URL=mongodb://mongo:mongo123@localhost:27017/soko_notifications

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis123
REDIS_URL=redis://:redis123@localhost:6379

# Elasticsearch
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=elastic123
ELASTICSEARCH_URL=http://localhost:9200

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=rabbitmq
RABBITMQ_PASSWORD=rabbitmq123
RABBITMQ_URL=amqp://rabbitmq:rabbitmq123@localhost:5672

# =====================================================
# AUTHENTICATION / JWT
# =====================================================
JWT_SECRET=your-super-secret-jwt-key
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d
ENCRYPTION_KEY=your-32-character-encryption-key
BCRYPT_SALT_ROUNDS=12
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=http://localhost:3000

# =====================================================
# EMAIL (SMTP)
# =====================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=Soko E-commerce
SMTP_FROM_EMAIL=noreply@soko.com

# =====================================================
# PAYMENT GATEWAYS
# =====================================================
# Stripe
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# PayPal
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox

# =====================================================
# CLOUDINARY FILE STORAGE
# =====================================================
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_UPLOAD_FOLDER=soko
CLOUDINARY_UPLOAD_PRESET=your_unsigned_upload_preset_optional
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
NEXT_PUBLIC_CLOUDINARY_URL=https://res.cloudinary.com/your_cloudinary_cloud_name

# =====================================================
# AWS / S3 FILE STORAGE (legacy/optional)
# =====================================================
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=soko-ecommerce
AWS_S3_ENDPOINT= # optional for non-AWS providers

# =====================================================
# CDN
# =====================================================
CDN_URL=https://cdn.soko.com
CDN_KEY=your_cdn_key

# =====================================================
# SMS & PUSH
# =====================================================
# Twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Firebase Push Notifications
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY=your-firebase-private-key
FIREBASE_CLIENT_EMAIL=your-firebase-client-email

# =====================================================
# FRONTEND / API
# =====================================================
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =====================================================
# CORS & SECURITY
# =====================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
HELMET_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# =====================================================
# LOGGING & MONITORING
# =====================================================
LOG_LEVEL=info
LOG_FORMAT=combined
LOG_DIR=./logs

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
LOKI_URL=http://localhost:3100

# =====================================================
# PERFORMANCE
# =====================================================
CACHE_TTL=300           # 5 minutes
SESSION_TTL=86400       # 24 hours
UPLOAD_LIMIT=52428800   # 50MB

# =====================================================
# FEATURE FLAGS
# =====================================================
FEATURE_CHAT_ENABLED=true
FEATURE_REVIEWS_ENABLED=true
FEATURE_WISHLIST_ENABLED=true
FEATURE_COUPONS_ENABLED=true
FEATURE_SOCIAL_LOGIN_ENABLED=true
FEATURE_TWO_FACTOR_AUTH=false

# =====================================================
# COMPANY INFO
# =====================================================
COMPANY_NAME=Soko E-commerce
COMPANY_EMAIL=support@soko.com
COMPANY_PHONE=+1234567890
COMPANY_ADDRESS=123 Market St, Nairobi, Kenya
SUPPORT_EMAIL=support@soko.com
SUPPORT_PHONE=+1234567890

# =====================================================
# SOCIAL LOGIN
# =====================================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
FACEBOOK_CLIENT_ID=your_facebook_client_id
FACEBOOK_CLIENT_SECRET=your_facebook_client_secret

# =====================================================
# ANALYTICS
# =====================================================
GOOGLE_ANALYTICS_ID=UA-XXXXX-Y
FACEBOOK_PIXEL_ID=your_facebook_pixel_id
